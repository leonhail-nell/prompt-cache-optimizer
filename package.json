{
  "name": "prompt-cache-optimizer",
  "version": "0.1.0",
  "description": "Drop-in wrapper for the Anthropic SDK that places cache_control breakpoints, measures cache hit rate, and warns when your prompt caching silently breaks.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "example": "tsx examples/basic-chatbot.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "anthropic",
    "claude",
    "prompt-caching",
    "cache",
    "llm",
    "ai",
    "cost-optimization",
    "tokens"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.27.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18"
  }
}
